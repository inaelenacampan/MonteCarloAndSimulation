simulate_MA2 <- function(theta, n) {
  theta1 = theta[1]
  theta2 = theta[2]
  
  z = rnorm(n + 2)  # bruit
  x = numeric(n)
  
  for (t in 3:(n + 2)) {
    x[t - 2] = z[t] + theta1 * z[t - 1] + theta2 * z[t - 2]
  }
  
  return(x)
}


