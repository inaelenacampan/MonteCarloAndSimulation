compute_stats <- function(samples) {  # fonction de résumé (moyenne et variance)
  return(c(
    mean_theta1 = mean(samples[,1]),
    mean_theta2 = mean(samples[,2]),
    var_theta1  = var(samples[,1]),
    var_theta2  = var(samples[,2])
  ))
}

