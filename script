### Les trois modèles ###


## 1) Modèle ABC-rejection basique pour le départ ## 

ABC_rejection <- function(N, epsilon) {
  
  samples = matrix(NA, N, 2)
  accepted = 0
  
  while (accepted < N) {
    
    theta = runif(2, -1, 1)   # prior
    
    x_sim = simulate_MA2(theta, n)
    s_sim = acf_stats(x_sim)
    
    dist = sum((s_sim - s_obs)^2)
    
    if (dist < epsilon) {
      accepted = accepted + 1
      samples[accepted, ] = theta
    }
  }
  
  return(samples)
}

samples_rej = ABC_rejection(1000, epsilon = 0.1)
colMeans(samples_rej)
# on trouve (0.59, 0.09)



## Modèle ABC-MCMC ##

ABC_MCMC <- function(N, epsilon, sigma) {
  
  chain = matrix(NA, nrow=N, ncol=2)
  
  # initialisation
  theta_current = c(0, 0)
  
  for (i in 1:N) {
    
    # proposal
    theta_prop = theta_current + rnorm(2, 0, sigma)
    
    # prior uniforme [-1,1]
    if (any(theta_prop < -1 | theta_prop > 1)) {
      chain[i, ] = theta_current
      next
    }
    
    # simulation
    x_sim = simulate_MA2(theta_prop, n)
    s_sim = acf_stats(x_sim)
    
    dist = sum((s_sim - s_obs)^2)
    
    if (dist < epsilon) {
      theta_current = theta_prop
    }
    
    chain[i, ] = theta_current
  }
  
  return(chain)
}

