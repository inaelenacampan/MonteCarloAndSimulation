## 2) Modèle Metropolis-Hastings ## 

log_likelihood_MA2 <- function(theta, x) {
  
  theta1 = theta[1]
  theta2 = theta[2]
  
  n = length(x)
  
  # reconstruction des innovations (approx)
  z = numeric(n)
  
  z[1] = x[1]
  z[2] = x[2] - theta1 * z[1]
  
  for (t in 3:n) {
    z[t] = x[t] - theta1 * z[t-1] - theta2 * z[t-2]
  }
  
  # densité normale des innovations
  ll = sum(dnorm(z, mean = 0, sd = 1, log = TRUE))
  
  return(ll)
}


MH_MA2 <- function(N, sigma) {      # Metropolis Hastings
  
  chain = matrix(NA, nrow = N, ncol = 2)
  
  # initialisation
  theta_current = c(0, 0)
  ll_current = log_likelihood_MA2(theta_current, x_obs)
  
  accept = 0
  
  for (i in 1:N) {
    
    # proposal random walk
    theta_prop = theta_current + rnorm(2, 0, sigma)
    
    # prior uniforme [-1,1]
    if (any(theta_prop < -1 | theta_prop > 1)) {
      chain[i, ] = theta_current
      next
    }
    
    ll_prop = log_likelihood_MA2(theta_prop, x_obs)
    
    # log acceptance ratio
    log_alpha = ll_prop - ll_current
    
    if (log(runif(1)) < log_alpha) {
      theta_current = theta_prop
      ll_current = ll_prop
      accept = accept + 1
    }
    
    chain[i, ] = theta_current
  }
  
  cat("Acceptance rate:", accept / N, "\n")
  
  return(chain)
}


